# ============================================================
# Wiki.js — Variabile de mediu necesare pentru deploy
# ============================================================
# IMPORTANT: Nu comite niciodată fișierul .env real în Git!
# Setează aceste valori direct în panoul Render → Environment.
# ============================================================

# Mediu de rulare
NODE_ENV=production

# Conexiune PostgreSQL — Neon.tech
# Găsești valorile în: neon.tech → Project → Connection Details → Parameters only
DB_HOST=ep-xxxxxxxxx.eu-central-1.aws.neon.tech
DB_PORT=5432
DB_USER=wiki_db_owner
DB_PASS=parola_generata_de_neon
DB_NAME=wiki_db
